DATABASE_URL=sqlite:///./data/sow_agent.db
SECRET_KEY=replace-with-openssl-rand-hex-32
DEV_LOGIN_EMAIL=dev@example.gov
DEV_LOGIN_PASSWORD=devpassword-change-me
MAX_UPLOAD_BYTES=26214400
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Choose one LLM provider for local runs (copy to .env and fill in).
# The app does not read LLM_PROVIDER; it uses Azure when AZURE_OPENAI_ENDPOINT and AZURE_OPENAI_DEPLOYMENT
# are both non-empty, otherwise OpenAI when OPENAI_API_KEY is set.
# - OpenAI: set OPENAI_API_KEY (and optionally LLM_MODEL).
# - Azure OpenAI: set AZURE_OPENAI_ENDPOINT, AZURE_OPENAI_DEPLOYMENT, and either
#   AZURE_OPENAI_API_KEY or managed identity in Azure; do not set OPENAI_API_KEY unless you intend to use both.
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Azure OpenAI (optional alternative to OpenAI for local dev—same variables work in .env):
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# LangSmith observability (optional): traces, latency, token usage in https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=federal-sow-agent

