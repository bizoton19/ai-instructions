DATABASE_URL=sqlite:///./data/sow_agent.db
SECRET_KEY=replace-with-openssl-rand-hex-32
DEV_LOGIN_EMAIL=dev@example.gov
DEV_LOGIN_PASSWORD=devpassword-change-me
MAX_UPLOAD_BYTES=26214400
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Choose one LLM provider:
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Azure OpenAI (optional alternative):
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# LangSmith observability (optional): traces, latency, token usage in https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=federal-sow-agent

